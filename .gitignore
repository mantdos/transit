# 依赖（各子项目 npm install）
node_modules/

# Vercel CLI：`vercel dev` / `vercel link` 生成的项目链接与缓存
.vercel/

# 环境变量与本地密钥（含 `vercel env pull`、本地覆盖等）
.env
.env.*
!.env.example
!.env.sample
!.env*.example

# 日志与调试
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 构建产物（若后续有打包步骤）
dist/
build/
out/
.next/
.nuxt/
.output/

# 覆盖率与缓存
coverage/
.nyc_output/
.cache/
.turbo/
*.tsbuildinfo

# 操作系统
.DS_Store
Thumbs.db
Desktop.ini

# 编辑器（个人配置不入库；若需共享团队设置可删掉下面两行）
.idea/
*.swp
*.swo
