{
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "/api/proxy?path=$1"
    },
    {
      "source": "/tutorial",
      "destination": "/tutorial.html"
    },
    {
      "source": "/setting",
      "destination": "/setting.html"
    },
    {
      "source": "/claudecode-config",
      "destination": "/setting.html"
    },
    {
      "source": "/claude-code",
      "destination": "/setting.html"
    },
    {
      "source": "/usage",
      "destination": "/usage.html"
    },
    {
      "source": "/models",
      "destination": "/models.html"
    }
  ],
  "functions": {
    "api/proxy.js": {
      "maxDuration": 300
    },
    "api/check.js": {
      "maxDuration": 60
    },
    "api/models.js": {
      "maxDuration": 60
    },
    "api/pricing.js": {
      "maxDuration": 60
    }
  }
}
